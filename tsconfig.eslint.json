{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": [
      "dom",
      "scripthost",
      "es2015",
      "es2016",
      "es2017",
      "es2018",
      "es2019",
      "es2020",
      "es2021",
      "es2022",
      "es2023",
      "esnext"
    ],
    "noEmit": true
  },
  "include": [
    "scripts/tests/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": [
    ".tmp",
    "dist",
    "extracted",
    "node_modules",
    "releases"
  ]
}
